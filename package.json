{
  "name": "@velocity/framework",
  "version": "0.1.0",
  "description": "A minimal, fast TypeScript framework with decorators, built-in ORM, and zero bloat.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "sync": "bun scripts/sync.js",
    "dev": "bun run build && bun run sync",
