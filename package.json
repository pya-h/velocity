    "envgen": "bun scripts/envgen.js",
    "apitester": "bun scripts/apitester.js",
    "demo": "cd examples/full-demo && bun run main.ts",
    "test": "bun test"
  },
  "keywords": ["typescript", "framework", "orm", "decorators", "minimal"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/bun": "^1.3.13",
    "joi": "^18.0.1",
    "mysql2": "^3.14.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "bun-types": "latest",
    "typescript": "^5.9.2"
  }
}
