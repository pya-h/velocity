{
  "name": "@velocity/framework",
  "version": "0.1.0",
  "description": "A minimal, fast TypeScript framework with decorators, built-in ORM, and zero bloat.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "sync": "node scripts/sync.js",
    "dev": "npm run build && npm run sync",
    "velogen": "node scripts/velogen.js",
    "envgen": "node scripts/envgen.js",
    "apitester": "node scripts/apitester.js",
    "demo": "cd examples/full-demo && node -r ../../node_modules/ts-node/register main.ts",
    "test": "jest"
  },
  "keywords": ["typescript", "framework", "orm", "decorators", "minimal"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "joi": "^18.0.1",
    "mysql2": "^3.14.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.2",
    "ts-node": "^10.9.2"
  }
}
